# Database
DATABASE_CLIENT=postgres
DATABASE_URL=postgresql://ledgerise:ledgerise@localhost:5432/ledgerise
# MySQL alternative if needed later:
# DATABASE_CLIENT=mysql
# DATABASE_URL=mysql://ledgerise:ledgerise@localhost:3306/ledgerise

# Queue / cache
# Optional. Leave blank until the worker queue is implemented.
REDIS_URL=

# Engine
ENGINE_SCHEDULE_CRON=0 * * * *
ENGINE_BATCH_SIZE=500
SUSPENSE_ACCOUNT_CODE=199999

# API
API_PORT=3000
DEFAULT_OPERATOR_SLUG=local-operator
# Optional. If set, this takes precedence over DEFAULT_OPERATOR_SLUG.
# DEFAULT_OPERATOR_ID=

# Web
WEB_PORT=3001
